MECHANOSCOPE_ENVIRONMENT=development
MECHANOSCOPE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MECHANOSCOPE_HF_ACCESS_CONFIGURED=false

# The actual Hugging Face token belongs in a Modal Secret, not this file.
MECHANOSCOPE_HF_SECRET_NAME=huggingface-secret
MECHANOSCOPE_MODAL_JLENS_APP_NAME=mechanoscope
MECHANOSCOPE_EXPERIMENT_DB_PATH=.data/mechanoscope-experiments.sqlite3
MODAL_ENVIRONMENT=main
