      "ActivationSteeringRequest": {
        "additionalProperties": false,
        "properties": {
          "layer": {
            "default": 18,
            "maximum": 128.0,
            "minimum": 0.0,
            "title": "Layer",
            "type": "integer"
          },
          "max_new_tokens": {
            "default": 96,
            "maximum": 128.0,
            "minimum": 1.0,
