      "ExperimentEnvelope": {
        "properties": {
          "experiment_id": {
            "title": "Experiment Id",
            "type": "string"
          },
          "finished_at": {
            "format": "date-time",
            "title": "Finished At",
            "type": "string"
          },
          "lineage_operation": {
            "anyOf": [
              {
                "enum": [
                  "replay",
                  "fork"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lineage Operation"
          },
          "parent_experiment_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Parent Experiment Id"
          },
          "request": {
            "discriminator": {
              "mapping": {
                "activation_steering": "#/components/schemas/ActivationSteeringExperimentRequest",
                "jacobian_lens": "#/components/schemas/JacobianLensExperimentRequest"
              },
              "propertyName": "technique_id"
            },
            "oneOf": [
              {
                "$ref": "#/components/schemas/JacobianLensExperimentRequest"
              },
              {
                "$ref": "#/components/schemas/ActivationSteeringExperimentRequest"
              }
            ],
            "title": "Request"
          },
          "result": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/JacobianLensResponse"
              },
              {
                "$ref": "#/components/schemas/ActivationSteeringResponse"
              }
            ],
            "title": "Result"
          },
          "schema_version": {
            "const": 1,
            "default": 1,
            "title": "Schema Version",
            "type": "integer"
          },
          "started_at": {
            "format": "date-time",
            "title": "Started At",
            "type": "string"
          },
          "status": {
            "const": "complete",
            "default": "complete",
            "title": "Status",
            "type": "string"
          },
          "technique_id": {
            "title": "Technique Id",
            "type": "string"
          }
        },
        "required": [
          "experiment_id",
          "technique_id",
          "started_at",
          "finished_at",
          "request",
          "result"
        ],
        "title": "ExperimentEnvelope",
        "type": "object"
      },
      "ExperimentForkRequest": {
