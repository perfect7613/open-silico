            "maxItems": 8,
            "minItems": 1,
            "title": "Negative Examples",
            "type": "array"
          },
          "positive_examples": {
            "items": {
              "type": "string"
            },
            "maxItems": 8,
            "minItems": 1,
            "title": "Positive Examples",
            "type": "array"
          },
          "prompt": {
            "maxLength": 4000,
            "minLength": 1,
            "title": "Prompt",
            "type": "string"
          },
          "seed": {
            "default": 16,
            "maximum": 2147483647.0,
            "minimum": 0.0,
            "title": "Seed",
            "type": "integer"
          },
          "strength": {
            "default": 1.0,
            "maximum": 100.0,
            "minimum": -100.0,
            "title": "Strength",
            "type": "number"
          },
          "temperature": {
            "default": 0.7,
            "maximum": 2.0,
            "minimum": 0.0,
            "title": "Temperature",
            "type": "number"
          },
          "top_p": {
            "default": 0.9,
            "exclusiveMinimum": 0.0,
            "maximum": 1.0,
            "title": "Top P",
            "type": "number"
          }
        },
        "required": [
          "prompt",
          "positive_examples",
          "negative_examples"
        ],
        "title": "ActivationSteeringRequest",
        "type": "object"
      },
      "ActivationSteeringResponse": {
